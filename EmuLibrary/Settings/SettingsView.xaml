<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             x:Class="EmuLibrary.Settings.SettingsView"
             xmlns:sys="clr-namespace:System;assembly=mscorlib" 
             xmlns:elrt="clr-namespace:EmuLibrary.RomTypes" 
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="RomTypeValues"
                            ObjectType="{x:Type sys:Enum}"
                            MethodName="GetValues">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="elrt:RomType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        
        <!-- Style for section headers -->
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <!-- Style for delete button -->
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="ToolTip" Value="Delete this mapping"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <TextBlock Text="✕" 
                                      FontSize="14" 
                                      Foreground="#D32F2F"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style for browse buttons -->
        <Style x:Key="BrowseButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="20">
        <StackPanel x:Name="EmulatorSettingsPanel">
            
            <!-- Emulator Mappings Section -->
            <GroupBox Header="Emulator Path Mappings" Padding="12" Margin="0,0,0,20">
                <GroupBox.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Emulator Path Mappings" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Margin="8,0,0,0">
                                <Hyperlink NavigateUri="https://github.com/psychonic/Playnite-EmuLibrary/blob/master/README.md#setup" 
                                          RequestNavigate="Hyperlink_RequestNavigate"
                                          Foreground="#1976D2">
                                    <Run Text="Help"/>
                                    <Run Text="🔗" FontSize="10"/>
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </GroupBox.HeaderTemplate>
                
                <DataGrid ItemsSource="{Binding Mappings}" 
                         AutoGenerateColumns="False" 
                         CellEditEnding="DataGrid_CellEditEnding" 
                         CurrentCellChanged="DataGrid_CurrentCellChanged" 
                         SelectionUnit="Cell" 
                         CanUserAddRows="True"
                         CanUserDeleteRows="False"
                         HeadersVisibility="Column"
                         GridLinesVisibility="Horizontal"
                         AlternatingRowBackground="#F5F5F5"
                         RowBackground="White"
                         BorderThickness="1"
                         BorderBrush="#E0E0E0"
                         Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="50" CanUserResize="False">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="" Width="50"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource DeleteButtonStyle}" 
                                           Tag="{Binding}" 
                                           Click="Click_Delete"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBlock Text=""/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Header="Emulator" Width="*" MinWidth="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=Emulator.Name, UpdateSourceTrigger=PropertyChanged}" 
                                              VerticalAlignment="Center"
                                              Margin="4,0"
                                              TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox Name="ComboEmulators"
                                             ItemsSource="{Binding AvailableEmulators}"
                                             DisplayMemberPath="Name"
                                             SelectedItem="{Binding Emulator, Mode=TwoWay}"
                                             Margin="2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Profile" Width="*" MinWidth="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=EmulatorProfile.Name, UpdateSourceTrigger=PropertyChanged}" 
                                              VerticalAlignment="Center"
                                              Margin="4,0"
                                              TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox Name="ComboProfiles"
                                             ItemsSource="{Binding AvailableProfiles}"
                                             DisplayMemberPath="Name"
                                             SelectedItem="{Binding EmulatorProfile, Mode=TwoWay}"
                                             Margin="2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Platform" Width="*" MinWidth="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=Platform.Name, UpdateSourceTrigger=PropertyChanged}" 
                                              VerticalAlignment="Center"
                                              Margin="4,0"
                                              TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox Name="ComboPlatforms"
                                             ItemsSource="{Binding AvailablePlatforms}"
                                             DisplayMemberPath="Name"
                                             SelectedItem="{Binding Platform, Mode=TwoWay}"
                                             Margin="2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Rom Type" Width="*" MinWidth="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RomType, UpdateSourceTrigger=PropertyChanged}" 
                                              VerticalAlignment="Center"
                                              Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox Name="ComboRomTypes"
                                             ItemsSource="{Binding Source={StaticResource RomTypeValues}}"
                                             SelectedItem="{Binding RomType, Mode=TwoWay}"
                                             Margin="2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Source Path" Width="*" MinWidth="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                  Text="{Binding Path=SourcePath, UpdateSourceTrigger=PropertyChanged}" 
                                                  VerticalAlignment="Center"
                                                  Margin="4,0"
                                                  TextTrimming="CharacterEllipsis"
                                                  ToolTip="{Binding SourcePath}"/>
                                        <Button Grid.Column="1"
                                               Style="{StaticResource BrowseButtonStyle}"
                                               Content="Browse..."
                                               Tag="{Binding}"
                                               Click="Click_BrowseSource"
                                               Margin="2,0"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource BrowseButtonStyle}"
                                           Content="Browse..."
                                           Tag="{Binding}"
                                           Click="Click_BrowseSource"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Destination Path" Width="*" MinWidth="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                  Text="{Binding Path=DestinationPath, UpdateSourceTrigger=PropertyChanged}" 
                                                  VerticalAlignment="Center"
                                                  Margin="4,0"
                                                  TextTrimming="CharacterEllipsis"
                                                  ToolTip="{Binding DestinationPath}"/>
                                        <Button Grid.Column="1"
                                               Style="{StaticResource BrowseButtonStyle}"
                                               Content="Browse..."
                                               Tag="{Binding}"
                                               Click="Click_BrowseDestination"
                                               Margin="2,0"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource BrowseButtonStyle}"
                                           Content="Browse..."
                                           Tag="{Binding}"
                                           Click="Click_BrowseDestination"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridCheckBoxColumn Header="Enabled" 
                                               Binding="{Binding Enabled}" 
                                               Width="80"
                                               CanUserResize="False"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
            
            <!-- Library Scanning Section -->
            <GroupBox Header="Library Scanning" Padding="12" Margin="0,0,0,20">
                <StackPanel>
                    <CheckBox IsChecked="{Binding ScanGamesInFullScreen, Mode=TwoWay}" Margin="0,0,0,12">
                        <TextBlock Text="Enable game scanning in fullscreen mode" 
                                  TextWrapping="Wrap"
                                  Margin="4,0,0,0"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding AutoRemoveUninstalledGamesMissingFromSource, Mode=TwoWay}" Margin="0,0,0,0">
                        <TextBlock Text="Automatically remove non-installed games from library if missing from source" 
                                  TextWrapping="Wrap"
                                  Margin="4,0,0,0"/>
                    </CheckBox>
                </StackPanel>
            </GroupBox>
            
            <!-- Installation Section -->
            <GroupBox Header="Installation" Padding="12" Margin="0,0,0,20">
                <StackPanel>
                    <CheckBox IsChecked="{Binding NotifyOnInstallComplete, Mode=TwoWay}" Margin="0,0,0,12">
                        <TextBlock Text="Enable notification upon game install completion" 
                                  TextWrapping="Wrap"
                                  Margin="4,0,0,0"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding UseWindowsCopyDialogInDesktopMode, Mode=TwoWay}" 
                             ToolTip="Game installs will be performed natively by Windows. The Copy File dialog box will be displayed to show installation progress."
                             Margin="0,0,0,12">
                        <TextBlock Text="Show Windows copy dialog in desktop mode" 
                                  TextWrapping="Wrap"
                                  Margin="4,0,0,0"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding UseWindowsCopyDialogInFullscreenMode, Mode=TwoWay}" 
                             ToolTip="Game installs will be performed natively by Windows. The Copy File dialog box will be displayed to show installation progress. Please note that enabling this option may cause issues with focus in fullscreen mode."
                             Margin="0,0,0,0">
                        <TextBlock Text="Show Windows copy dialog in fullscreen mode" 
                                  TextWrapping="Wrap"
                                  Margin="4,0,0,0"/>
                    </CheckBox>
                </StackPanel>
            </GroupBox>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>