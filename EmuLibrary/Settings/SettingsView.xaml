<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             x:Class="EmuLibrary.Settings.SettingsView"
             xmlns:sys="clr-namespace:System;assembly=mscorlib" 
             xmlns:elrt="clr-namespace:EmuLibrary.RomTypes" 
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="RomTypeValues"
                            ObjectType="{x:Type sys:Enum}"
                            MethodName="GetValues">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="elrt:RomType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        
        <!-- Style for delete button with theme support -->
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="ToolTip" Value="Delete this mapping"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <TextBlock Text="✕"
                                      FontSize="14"
                                      Foreground="{DynamicResource WarningBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Opacity="0.8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                <Setter Property="Opacity" Value="1.0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style for help text -->
        <Style x:Key="HelpTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrushDark}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="4,4,0,0"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>

        <!-- Style for section description -->
        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrushDarker}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>

        <!-- Style for DataGrid column headers -->
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Style for DataGrid cells -->
        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="20">
        <StackPanel x:Name="EmulatorSettingsPanel">
            
            <!-- Emulator Mappings Section -->
            <GroupBox Padding="12" Margin="0,0,0,20">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Emulator Path Mappings" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Margin="8,0,0,0">
                            <Hyperlink NavigateUri="https://github.com/psychonic/Playnite-EmuLibrary/blob/master/README.md#setup"
                                      RequestNavigate="Hyperlink_RequestNavigate">
                                <Run Text="Help"/>
                                <Run Text="🔗" FontSize="10"/>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </GroupBox.Header>
                
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionDescriptionStyle}">
                        Configure mappings that combine an emulator, profile, platform, and ROM type to scan for games. 
                        Each mapping defines where to find games (source path) and where to install them (destination path).
                        <LineBreak/><LineBreak/>
                        <Run Text="Fields marked with " FontWeight="Bold"/>
                        <Run Text="*" Foreground="Red" FontWeight="Bold"/>
                        <Run Text=" are required." FontWeight="Bold"/>
                    </TextBlock>
                
                <DataGrid ItemsSource="{Binding Mappings}"
                         AutoGenerateColumns="False"
                         CellEditEnding="DataGrid_CellEditEnding"
                         SelectionUnit="Cell"
                         CanUserAddRows="True"
                         CanUserDeleteRows="False"
                         CanUserReorderColumns="False"
                         HeadersVisibility="Column"
                         GridLinesVisibility="Horizontal"
                         RowBackground="{DynamicResource ControlBackgroundBrush}"
                         Background="{DynamicResource ControlBackgroundBrush}"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource NormalBorderBrush}"
                         Foreground="{DynamicResource TextBrush}"
                         ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                         CellStyle="{StaticResource DataGridCellStyle}"
                         Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="50" CanUserResize="False">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="" Width="50"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource DeleteButtonStyle}" 
                                           Tag="{Binding}" 
                                           Click="Click_Delete"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBlock Text=""/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Width="*" MinWidth="140">
                            <DataGridTemplateColumn.Header>
                                <TextBlock>
                                    <Run Text="Emulator"/>
                                    <Run Text="*" Foreground="Red"/>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                    <Setter Property="ToolTip" Value="The emulator to use for this mapping. Select from configured emulators in Playnite."/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=Emulator.Name, UpdateSourceTrigger=PropertyChanged}" 
                                              VerticalAlignment="Center"
                                              Margin="4,0"
                                              TextTrimming="CharacterEllipsis"
                                              ToolTip="{Binding Path=Emulator.Name}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox Name="ComboEmulators"
                                             ItemsSource="{Binding AvailableEmulators}"
                                             DisplayMemberPath="Name"
                                             SelectedItem="{Binding Emulator, Mode=TwoWay}"
                                             Margin="2"
                                             ToolTip="Select the emulator for this mapping"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*" MinWidth="140">
                            <DataGridTemplateColumn.Header>
                                <TextBlock>
                                    <Run Text="Profile"/>
                                    <Run Text="*" Foreground="Red"/>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                    <Setter Property="ToolTip" Value="The emulator profile to use. Profiles define how the emulator launches games and which file extensions it supports."/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=EmulatorProfile.Name, UpdateSourceTrigger=PropertyChanged}" 
                                              VerticalAlignment="Center"
                                              Margin="4,0"
                                              TextTrimming="CharacterEllipsis"
                                              ToolTip="{Binding Path=EmulatorProfile.Name}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox Name="ComboProfiles"
                                             ItemsSource="{Binding AvailableProfiles}"
                                             DisplayMemberPath="Name"
                                             SelectedItem="{Binding EmulatorProfile, Mode=TwoWay}"
                                             Margin="2"
                                             ToolTip="Select the emulator profile for this mapping"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*" MinWidth="140">
                            <DataGridTemplateColumn.Header>
                                <TextBlock>
                                    <Run Text="Platform"/>
                                    <Run Text="*" Foreground="Red"/>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                    <Setter Property="ToolTip" Value="The platform/console for the games in this mapping (e.g., PlayStation 2, Nintendo Switch, Windows, etc.)."/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=Platform.Name, UpdateSourceTrigger=PropertyChanged}" 
                                              VerticalAlignment="Center"
                                              Margin="4,0"
                                              TextTrimming="CharacterEllipsis"
                                              ToolTip="{Binding Path=Platform.Name}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox Name="ComboPlatforms"
                                             ItemsSource="{Binding AvailablePlatforms}"
                                             DisplayMemberPath="Name"
                                             SelectedItem="{Binding Platform, Mode=TwoWay}"
                                             Margin="2"
                                             ToolTip="Select the platform for this mapping"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*" MinWidth="120">
                            <DataGridTemplateColumn.Header>
                                <TextBlock>
                                    <Run Text="ROM Type"/>
                                    <Run Text="*" Foreground="Red"/>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                    <Setter Property="ToolTip" Value="The type of ROM/installer: SingleFile (one file per game), MultiFile (folder per game), PCInstaller (handles EXE, ISO, and archives), or Yuzu (Nintendo Switch)."/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RomType, UpdateSourceTrigger=PropertyChanged}" 
                                              VerticalAlignment="Center"
                                              Margin="4,0"
                                              ToolTip="{Binding RomType}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox Name="ComboRomTypes"
                                             ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=FilteredRomTypes}"
                                             SelectedItem="{Binding RomType, Mode=TwoWay}"
                                             Margin="2"
                                             ToolTip="Select the ROM type for this mapping"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*" MinWidth="200">
                            <DataGridTemplateColumn.Header>
                                <TextBlock>
                                    <Run Text="Source Path"/>
                                    <Run Text="*" Foreground="Red"/>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                    <Setter Property="ToolTip" Value="The folder path where GameVault will scan for games. This can be a local path, network share (UNC), or mapped drive. Games are scanned from this location but remain there until installed."/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                  Text="{Binding Path=SourcePath, UpdateSourceTrigger=PropertyChanged}" 
                                                  VerticalAlignment="Center"
                                                  Margin="4,0"
                                                  TextTrimming="CharacterEllipsis"
                                                  ToolTip="{Binding SourcePath}"/>
                                        <Button Grid.Column="1"
                                               Content="Browse..."
                                               Tag="{Binding}"
                                               Click="Click_BrowseSource"
                                               Margin="2,0"
                                               Padding="8,4"
                                               MinWidth="70"
                                               Cursor="Hand"
                                               ToolTip="Browse for the source folder containing games"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <Button Content="Browse..."
                                           Tag="{Binding}"
                                           Click="Click_BrowseSource"
                                           Padding="8,4"
                                           MinWidth="70"
                                           ToolTip="Browse for the source folder containing games"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*" MinWidth="200">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="Destination Path"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                    <Setter Property="ToolTip" Value="The folder path where games will be installed when you choose to install them. For PCInstaller type, this can be set during installation. For portable Playnite installations, paths relative to Playnite directory are preserved."/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                  Text="{Binding Path=DestinationPath, UpdateSourceTrigger=PropertyChanged}" 
                                                  VerticalAlignment="Center"
                                                  Margin="4,0"
                                                  TextTrimming="CharacterEllipsis"
                                                  ToolTip="{Binding DestinationPath}"/>
                                        <Button Grid.Column="1"
                                               Content="Browse..."
                                               Tag="{Binding}"
                                               Click="Click_BrowseDestination"
                                               Margin="2,0"
                                               Padding="8,4"
                                               MinWidth="70"
                                               Cursor="Hand"
                                               ToolTip="Browse for the destination folder where games will be installed"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <Button Content="Browse..."
                                           Tag="{Binding}"
                                           Click="Click_BrowseDestination"
                                           Padding="8,4"
                                           MinWidth="70"
                                           ToolTip="Browse for the destination folder where games will be installed"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridCheckBoxColumn Width="80" CanUserResize="False">
                            <DataGridCheckBoxColumn.Header>
                                <TextBlock Text="Enabled" ToolTip="Enable or disable this mapping. Disabled mappings are not scanned during library updates."/>
                            </DataGridCheckBoxColumn.Header>
                            <DataGridCheckBoxColumn.Binding>
                                <Binding Path="Enabled"/>
                            </DataGridCheckBoxColumn.Binding>
                        </DataGridCheckBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>
                </StackPanel>
            </GroupBox>
            
            <!-- Library Scanning Section -->
            <GroupBox Padding="12" Margin="0,0,0,20">
                <GroupBox.Header>
                    <TextBlock Text="Library Scanning" FontWeight="SemiBold" FontSize="14"/>
                </GroupBox.Header>
                
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionDescriptionStyle}">
                        Configure how GameVault scans for games and manages your library.
                    </TextBlock>
                    
                    <CheckBox IsChecked="{Binding ScanGamesInFullScreen, Mode=TwoWay}" Margin="0,0,0,12">
                        <CheckBox.ToolTip>
                            <TextBlock TextWrapping="Wrap" MaxWidth="400">
                                When enabled, GameVault will scan for games even when Playnite is running in Fullscreen mode.
                                By default, scanning is disabled in Fullscreen mode to avoid performance issues.
                            </TextBlock>
                        </CheckBox.ToolTip>
                        <TextBlock Text="Enable game scanning in fullscreen mode" 
                                  TextWrapping="Wrap"
                                  Margin="4,0,0,0"/>
                    </CheckBox>
                    
                    <CheckBox IsChecked="{Binding AutoRemoveUninstalledGamesMissingFromSource, Mode=TwoWay}" Margin="0,0,0,0">
                        <CheckBox.ToolTip>
                            <TextBlock TextWrapping="Wrap" MaxWidth="400">
                                When enabled, games that are not installed and are missing from the source folder will be automatically removed from your Playnite library during library updates. 
                                This helps keep your library clean when you delete or move source files.
                            </TextBlock>
                        </CheckBox.ToolTip>
                        <TextBlock Text="Automatically remove non-installed games from library if missing from source" 
                                  TextWrapping="Wrap"
                                  Margin="4,0,0,0"/>
                    </CheckBox>
                </StackPanel>
            </GroupBox>
            
            <!-- Installation Section -->
            <GroupBox Padding="12" Margin="0,0,0,20">
                <GroupBox.Header>
                    <TextBlock Text="Installation" FontWeight="SemiBold" FontSize="14"/>
                </GroupBox.Header>
                
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionDescriptionStyle}">
                        Configure installation behavior and progress display options.
                    </TextBlock>
                    
                    <CheckBox IsChecked="{Binding NotifyOnInstallComplete, Mode=TwoWay}" Margin="0,0,0,12">
                        <CheckBox.ToolTip>
                            <TextBlock TextWrapping="Wrap" MaxWidth="400">
                                When enabled, Playnite will show a notification when a game installation completes. 
                                This helps you know when games are ready to play.
                            </TextBlock>
                        </CheckBox.ToolTip>
                        <TextBlock Text="Enable notification upon game install completion" 
                                  TextWrapping="Wrap"
                                  Margin="4,0,0,0"/>
                    </CheckBox>
                    
                    <CheckBox IsChecked="{Binding UseWindowsCopyDialogInDesktopMode, Mode=TwoWay}" Margin="0,0,0,12">
                        <CheckBox.ToolTip>
                            <TextBlock TextWrapping="Wrap" MaxWidth="400">
                                When enabled, game installations will use Windows' native file copy dialog to show progress. 
                                This provides detailed progress information including transfer speed and time remaining. 
                                Recommended for desktop mode.
                            </TextBlock>
                        </CheckBox.ToolTip>
                        <TextBlock Text="Show Windows copy dialog in desktop mode" 
                                  TextWrapping="Wrap"
                                  Margin="4,0,0,0"/>
                    </CheckBox>
                    
                    <CheckBox IsChecked="{Binding UseWindowsCopyDialogInFullscreenMode, Mode=TwoWay}" Margin="0,0,0,0">
                        <CheckBox.ToolTip>
                            <TextBlock TextWrapping="Wrap" MaxWidth="400">
                                <Run Text="When enabled, game installations will use Windows' native file copy dialog in Fullscreen mode."/>
                                <LineBreak/><LineBreak/>
                                <Run Text="Warning: " FontWeight="Bold"/>
                                <Run Text="This may cause focus issues in Fullscreen mode, making the interface unresponsive until the copy dialog is closed. Only enable if you need detailed progress information in Fullscreen mode."/>
                            </TextBlock>
                        </CheckBox.ToolTip>
                        <TextBlock Text="Show Windows copy dialog in fullscreen mode" 
                                  TextWrapping="Wrap"
                                  Margin="4,0,0,0"/>
                    </CheckBox>
                </StackPanel>
            </GroupBox>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>